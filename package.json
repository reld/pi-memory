{
  "name": "@reld/pi-memory",
  "version": "0.1.0",
  "description": "Pi package providing per-project long-term memory with a TypeScript extension and Go backend.",
  "keywords": [
    "pi-package"
  ],
  "license": "MIT",
  "type": "module",
  "files": [
    "extensions",
    "src/extension",
    "resources",
    "docs",
    "README.md"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build:go": "./scripts/build-go.sh",
    "build:resources": "./scripts/build-resources.sh",
    "build": "tsc --noEmit && ./scripts/build-go.sh && ./scripts/build-resources.sh",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "@mariozechner/pi-ai": "*",
    "@mariozechner/pi-agent-core": "*",
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "packageManager": "npm@11.12.1"
}